# Database Configuration
DATABASE_URL=postgresql://user:pass@host/db

# Authentication Keys (RS256 Private/Public Pair encoded in base64)
JWT_PRIVATE_KEY=       # RS256 private key (base64)
JWT_PUBLIC_KEY=        # RS256 public key (base64)

# Encryption Keys (32-byte hex string)
ENCRYPTION_KEY=        # 32-byte hex string

# Mono Connect (Open Banking Integration)
MONO_SECRET_KEY=
MONO_PUBLIC_KEY=

# Paystack Payment Gateway Integration
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=

# App Server Configuration
PORT=3000
NODE_ENV=development
ALLOWED_ORIGINS=http://localhost:5173

# Frontend Configuration
VITE_API_URL=http://localhost:3000/api

# Gemini AI Engine Verification (Injected by AI Studio)
GEMINI_API_KEY=
